# Environment variable reference for rvc-web backend
#
# Copy this file to .env and fill in values for local development.
# None of these are secrets — all are safe to commit as examples.

# ---------------------------------------------------------------------------
# RVC_ROOT — path to the cloned Retrieval-based-Voice-Conversion-WebUI repo.
# Required by S02 (training pipeline) and S03 (realtime VC) — optional in S01.
# Example: /Users/yourname/code/Retrieval-based-Voice-Conversion-WebUI
# ---------------------------------------------------------------------------
RVC_ROOT=

# ---------------------------------------------------------------------------
# DATABASE_URL — SQLite connection string for aiosqlite.
# Defaults to sqlite+aiosqlite:///./backend/data/rvc.db if unset.
# Override to use an absolute path or a different DB location.
# ---------------------------------------------------------------------------
DATABASE_URL=sqlite+aiosqlite:///./backend/data/rvc.db

# ---------------------------------------------------------------------------
# DATA_DIR — root directory for uploaded sample files and runtime artifacts.
# Defaults to ./data relative to the repo root if unset.
# Example: /Users/yourname/code/rvc-web/data
# ---------------------------------------------------------------------------
DATA_DIR=
